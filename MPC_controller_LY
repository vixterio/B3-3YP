""" MPC_controller_LY.py

    Constrained linear MPC for the Sorensen linearised model.

    REQUIREMENT: 
    - The repository module LINEARISED_MODEL_TPB.py exports continuous-time linearisation:
        Ac : (n x n) continuous-time A matrix
        Bc : (n x m) continuous-time B matrix
        C : (1 x n) output matrix measuring glucose (row vector or 1D)
        tau_s : sampling time in MINUTES (scalar)
        Optionally:
        x_star : equilibrium state (n,)
        u_star : equilibrium input (m,)
        
    The script will:
    - Discretise (Ac,Bc) with a ZOH using tau_s (minutes -> seconds conversion).
    - Build and solve a constrained MPC QP (cvxpy, OSQP).
    - Simulate closed-loop on the discrete LTI plant x_{k+1} = A_d x_k + B_d u_k.
    - Plot glucose (C x) and control inputs (insulin, glucagon).

"""

import sys
import importlib
import numpy as np
import matplotlib.pyplot as plt
from scipy import signal
import cvxpy as cp
from collections import Counter

def load_continuous_linear_model():
    modname = "LINEARISED_MODEL_TPB"
    try:
        mod = importlib.import_module(modname)
    except Exception as e:
        raise RuntimeError(f"Unable to import module '{modname}'. Make sure '{modname}.py' is available. Error: {e}")

    A = getattr(mod, "A", None)
    B = getattr(mod, "B", None)
    C = getattr(mod, "C", None)
    tau_s = getattr(mod, "tau_s", None)

    missing = []
    if A is None: missing.append("A")
    if B is None: missing.append("B")
    if C is None: missing.append("C")
    if tau_s is None: missing.append("tau_s")
    if missing:
        raise RuntimeError(f"Missing in {modname}: {missing}")

    A = np.asarray(A, dtype=float)
    B = np.asarray(B, dtype=float)
    C = np.asarray(C, dtype=float)
    if C.ndim == 1:
        C = C.reshape((1, -1))
    tau_s = float(tau_s)
    x_star = getattr(mod, "x_star", None)
    u_star = getattr(mod, "u_star", None)

    return {"A": A, "B": B, "C": C, "tau_s": tau_s, "x_star": x_star, "u_star": u_star, "source": modname}

def zoh_discretise(A, B, tau_s_min):
    """Discretise (A,B) with ZOH. tau_s_min in minutes -> convert to seconds."""
    dt = float(tau_s_min) * 60.0
    A = np.asarray(A, dtype=float)
    B = np.asarray(B, dtype=float)
    C_dummy = np.zeros((1, A.shape[0]))
    D_dummy = np.zeros((1, B.shape[1]))
    try:
        out = signal.cont2discrete((A, B, C_dummy, D_dummy), dt, method="zoh")
        A_d, B_d = np.asarray(out[0]), np.asarray(out[1])
    except Exception:
        # fallback older signature
        A_d, B_d, _, _ = signal.cont2discrete((A, B, C_dummy, D_dummy), dt)
        A_d, B_d = np.asarray(A_d), np.asarray(B_d)
    return A_d, B_d

class MPCController:
    def __init__(self, A_d, B_d, C, tau_s=5.0, Np=25, Nc=15,
                 umin=None, umax=None, dumin=None, dumax=None,
                 lambda_u=None, y_min=-1e6, y_max=1e6):
        self.A = np.asarray(A_d, dtype=float)
        self.B = np.asarray(B_d, dtype=float)
        self.C = np.asarray(C, dtype=float).reshape((1, -1))
        self.tau_s = float(tau_s)
        self.Np = int(Np)
        self.Nc = int(min(Nc, Np))
        self.n = self.A.shape[0]
        self.m = self.B.shape[1]

        if umin is None: umin = np.zeros(self.m)
        if umax is None: umax = np.array([80.0, 0.5]) if self.m == 2 else np.ones(self.m)*1e6
        if dumin is None: dumin = -np.array([16.7, 0.1]) if self.m == 2 else -np.ones(self.m)*1e6
        if dumax is None: dumax = np.array([16.7, 0.1]) if self.m == 2 else np.ones(self.m)*1e6
        if lambda_u is None: lambda_u = np.eye(self.m)*1e-2

        self.umin = np.asarray(umin).reshape((self.m,))
        self.umax = np.asarray(umax).reshape((self.m,))
        self.dumin = np.asarray(dumin).reshape((self.m,))
        self.dumax = np.asarray(dumax).reshape((self.m,))
        self.lambda_u = np.asarray(lambda_u)
        if self.lambda_u.ndim == 1:
            self.lambda_u = np.diag(self.lambda_u)
        self.y_min = float(y_min); self.y_max = float(y_max)
        self._build_prediction_matrices()

    def _build_prediction_matrices(self):
        Phi_rows = []
        A_pow = np.eye(self.n)
        for i in range(1, self.Np+1):
            A_pow = A_pow @ self.A
            Phi_rows.append(self.C @ A_pow)
        self.Phi = np.vstack(Phi_rows)

        H_list = []
        A_pow = np.eye(self.n)
        for i in range(1, self.Np+1):
            H_list.append((self.C @ A_pow @ self.B).reshape((1, self.m)))
            A_pow = A_pow @ self.A

        Gamma_full = np.zeros((self.Np, self.m * self.Np))
        for row in range(self.Np):
            for col in range(row+1):
                Hi = H_list[row-col]
                Gamma_full[row, col*self.m:(col+1)*self.m] = Hi
        self.Gamma_full = Gamma_full
        self.Gamma = self.Gamma_full[:, :self.m*self.Nc]

    def compute_control(self, xk, uk_prev, r=0, solver=cp.OSQP, verbose=False):
        xk = np.asarray(xk).reshape((self.n,))
        uk_prev = np.asarray(uk_prev).reshape((self.m,))

        if np.isscalar(r):
            r_vec = np.ones((self.Np,1)) * float(r)
        else:
            r = np.asarray(r).reshape(-1)
            if r.size != self.Np:
                raise ValueError("r must be scalar or length Np")
            r_vec = r.reshape((self.Np,1))

        Y0 = (self.Phi @ xk).reshape((self.Np,1))
        deltaU = cp.Variable((self.m*self.Nc,1))

        m = self.m; Nc = self.Nc; Np = self.Np
        T = np.zeros((m*Nc, m*Nc))
        for i in range(Nc):
            for j in range(i+1):
                T[i*m:(i+1)*m, j*m:(j+1)*m] = np.eye(m)
        uk_prev_repeat = np.tile(uk_prev, Nc).reshape((-1,1))

        Gamma_T = self.Gamma @ T
        Gamma_u0 = self.Gamma @ uk_prev_repeat
        Y_pred = Y0 + Gamma_u0 + Gamma_T @ deltaU

        Lambda_block = np.kron(np.eye(Nc), self.lambda_u)
        obj = cp.sum_squares(Y_pred - r_vec) + cp.quad_form(deltaU, Lambda_block)

        constraints = []
        for i in range(Nc):
            du = deltaU[i*m:(i+1)*m, 0]
            constraints += [du >= self.dumin, du <= self.dumax]
        u_seq = uk_prev_repeat + T @ deltaU
        for i in range(Nc):
            ui = u_seq[i*m:(i+1)*m, 0]
            constraints += [ui >= self.umin, ui <= self.umax]
        constraints += [Y_pred >= self.y_min, Y_pred <= self.y_max]

        prob = cp.Problem(cp.Minimize(obj), constraints)
        prob.solve(solver=solver, verbose=verbose)

        if prob.status not in ["optimal", "optimal_inaccurate"]:
            return uk_prev.copy(), {"status": prob.status}

        deltaU_opt = np.array(deltaU.value).reshape(-1)
        du0 = deltaU_opt[:self.m]
        u0 = uk_prev + du0
        info = {"deltaU_opt": deltaU_opt, "Y_pred": Y_pred.value.reshape(-1), "qp_status": prob.status}
        return u0, info

def build_Bw_unit_output(C, n):
    C = np.asarray(C).reshape((1,-1))
    denom = float(C @ C.T)
    if np.abs(denom) < 1e-9:
        Bw = np.zeros((n,1)); Bw[0,0] = 1.0
    else:
        Bw = (C.T / denom).reshape((n,1))
    return Bw

def run_closed_loop_discrete_with_disturbance(A_d, B_d, C,
                                              meal_schedule=None,
                                              x_star=None, u_star=None,
                                              tau_s=5.0, sim_duration_min=2000,
                                              tau_absorb_min=60.0, mpc_params=None):
    A_d = np.asarray(A_d); B_d = np.asarray(B_d); C = np.asarray(C).reshape((1,-1))
    n = A_d.shape[0]; m = B_d.shape[1]

    if x_star is None:
        denom = float(C @ C.T)
        if np.abs(denom) < 1e-9:
            x_star = np.zeros(n); x_star[0] = 110.0
        else:
            x_star = (110.0 * C.T / denom).reshape((n,))

    if u_star is None:
        u_star = np.zeros(m)

    sim_steps = int(np.ceil(sim_duration_min / tau_s))
    t_vec = np.arange(sim_steps) * tau_s

    Ga_seq = np.zeros(sim_steps)
    if meal_schedule is None: meal_schedule = []
    for (tmin, tot) in meal_schedule:
        idx = int(np.round(tmin / tau_s))
        if 0 <= idx < sim_steps:
            Ga_seq[idx] += float(tot)

    y_star = float((C @ x_star).reshape(-1)[0])
    y_min_phys = 40.0; y_max_phys = 400.0
    y_min_dev = y_min_phys - y_star; y_max_dev = y_max_phys - y_star
    print(f"y_star={y_star:.4f} mg/dL -> constraining deviations in [{y_min_dev:.4f}, {y_max_dev:.4f}]")

    alpha = np.exp(-tau_s / tau_absorb_min)
    Bw = build_Bw_unit_output(C, n)  # shape (n,1)

    # Defaults
    Np = 25; Nc = 15
    lambda_u = np.diag([1e-4]*m)
    umin = np.zeros(m)
    umax = np.array([80.0, 0.5]) if m==2 else np.ones(m)*1e6
    dumin = -np.array([16.7, 0.1]) if m==2 else -np.ones(m)*1e6
    dumax = np.array([16.7, 0.1]) if m==2 else np.ones(m)*1e6

    if isinstance(mpc_params, dict):
        Np = int(mpc_params.get("Np", Np))
        Nc = int(mpc_params.get("Nc", Nc))
        lambda_u = mpc_params.get("lambda_u", lambda_u)
        umin = mpc_params.get("umin", umin)
        umax = mpc_params.get("umax", umax)
        dumin = mpc_params.get("dumin", dumin)
        dumax = mpc_params.get("dumax", dumax)
        if "y_min" in mpc_params and "y_max" in mpc_params:
            ymn = float(mpc_params["y_min"]); ymx = float(mpc_params["y_max"])
            y_min_dev = ymn - y_star; y_max_dev = ymx - y_star
            print(f"Overriding physical y-bounds from mpc_params -> [{ymn}, {ymx}] mg/dL; dev bounds [{y_min_dev}, {y_max_dev}]")

    mpc = MPCController(A_d, B_d, C, tau_s=tau_s, Np=Np, Nc=Nc,
                        umin=umin, umax=umax, dumin=dumin, dumax=dumax,
                        lambda_u=lambda_u, y_min=y_min_dev, y_max=y_max_dev)

    x_dev = np.zeros(n)
    u_prev_dev = np.zeros(m)
    ys_phys = np.zeros(sim_steps)
    xs_dev = np.zeros((sim_steps, n))
    us_dev = np.zeros((sim_steps, m))
    us_phys = np.zeros((sim_steps, m))
    g_app_hist = np.zeros(sim_steps)
    Ga = 0.0
    qp_status_list = []

    for k in range(sim_steps):
        y_dev = float((C @ x_dev)[0])
        y_phys = y_dev + y_star
        ys_phys[k] = y_phys
        xs_dev[k,:] = x_dev.copy()

        r_phys = 90.0
        r_dev = r_phys - y_star

        u_dev, info = mpc.compute_control(x_dev, u_prev_dev, r=r_dev)
        us_dev[k,:] = u_dev.copy()
        us_phys[k,:] = u_dev + u_star

        qp_status_list.append(info.get("qp_status","noinfo"))

        Ga = alpha*Ga + Ga_seq[k]
        app_amt_per_step = (1.0 - alpha) * Ga
        g_app_hist[k] = app_amt_per_step / tau_s

        x_dev = A_d @ x_dev + B_d @ u_dev + (Bw.flatten() * app_amt_per_step)

        u_prev_dev = u_dev.copy()

    print("QP status counts (this sim):", Counter(qp_status_list))
    return t_vec, ys_phys, xs_dev, us_dev, us_phys, g_app_hist

def main():
    try:
        model = load_continuous_linear_model()
    except RuntimeError as e:
        print("ERROR:", e); sys.exit(1)

    A = model["A"]; B = model["B"]; C = model["C"]; tau_s = model["tau_s"]
    x_star = model.get("x_star", None)
    u_star_model = model.get("u_star", None)
    source = model.get("source","LINEARISED_MODEL_TPB")

    print(f"Loaded continuous linear model from '{source}'. A shape {A.shape}, B shape {B.shape}, C shape {C.shape}, tau_s={tau_s} min")
    A_d, B_d = zoh_discretise(A, B, tau_s)
    print(f"Discretised with ZOH -> A_d shape {A_d.shape}, B_d shape {B_d.shape}")

    # Choose x_star: use provided if present, else pick one with y_star=90
    if x_star is None:
        denom = float((C @ C.T).reshape(()))
        if np.abs(denom) < 1e-9:
            x_star = np.zeros(A_d.shape[0]); x_star[0] = 90.0
        else:
            x_star = (90.0 * C.T / denom).reshape((-1,))
        print("No x_star in model -> creating x_star with y_star=90.0")
    else:
        print("Using x_star from model (if provided).")

    # IMPORTANT: force u_star = zeros to avoid steady offset 
    u_star = np.zeros(B_d.shape[1])
    print("Forcing u_star = zeros -> no steady insulin/glucagon at equilibrium.")

    # Meal schedule (paper-like)
    sim_minutes = 2000
    meal_schedule = [(60.0, 50.0), (360.0, 70.0), (720.0, 55.0)]

    # MPC tuning: paper horizons. Keep lambda moderate; adjust if needed.
    # Default symmetric lambda (can be tuned). We keep insulin and glucagon similar penalty here.
    lambda_u = np.diag([1e-4]*B_d.shape[1])
    mpc_params = {
        "Np": 25,
        "Nc": 15,
        "lambda_u": lambda_u,
        "umin": np.zeros(B_d.shape[1]),
        "umax": np.array([80.0, 0.5]) if B_d.shape[1]==2 else np.ones(B_d.shape[1])*1e6,
        "dumin": -np.array([16.7, 0.1]) if B_d.shape[1]==2 else -np.ones(B_d.shape[1])*1e6,
        "dumax": np.array([16.7, 0.1]) if B_d.shape[1]==2 else np.ones(B_d.shape[1])*1e6,
        "y_min": 60.0,
        "y_max": 110.0
    }

    print("C @ B_d (how each input affects output):", np.round((C @ B_d).reshape(-1),6))
    print("Using lambda_u diag:", np.diag(lambda_u))

    print("Simulating closed-loop on discrete LTI model.")
    t_vec, y_phys, x_dev_hist, u_dev_hist, u_phys_hist, g_app_hist = run_closed_loop_discrete_with_disturbance(
        A_d, B_d, C,
        meal_schedule=meal_schedule,
        x_star=x_star,
        u_star=u_star,
        tau_s=tau_s,
        sim_duration_min=sim_minutes,
        tau_absorb_min=90.0,
        mpc_params=mpc_params)

    # Diagnostics
    print("\n--- control diagnostics ---")
    print("u_star (if present) summary:", np.round(u_star,5))
    print("u_dev mean/std:", np.round(np.mean(u_dev_hist, axis=0),6), np.round(np.std(u_dev_hist, axis=0),6))
    print("u_phys mean/std:", np.round(np.mean(u_phys_hist, axis=0),6), np.round(np.std(u_phys_hist, axis=0),6))
    print("first 20 u_phys rows:\n", np.round(u_phys_hist[:20,:],6))
    print("--- end diagnostics ---\n")

    print("C @ x_star (y_star) = ", float((C @ x_star).reshape(-1)[0]))
    r_dev = 90.0 - float((C @ x_star).reshape(-1)[0])
    print("deviation setpoint r_dev (90 - y_star) =", r_dev)

    # Plot
    fig, axs = plt.subplots(4,1,figsize=(12,9),sharex=True, gridspec_kw={"height_ratios":[2,1,1,0.6]})
    axs[0].plot(t_vec, y_phys, label="Glucose (C x)")
    axs[0].axhline(90.0, ls="--", color="k", label="setpoint 90 mg/dL")
    axs[0].set_ylabel("Glucose (mg/dL)"); axs[0].set_ylim([60,100]); axs[0].legend(loc="upper right"); axs[0].grid(True)

    axs[1].step(t_vec, u_phys_hist[:,0], where='post', label="Insulin infusion (mU/min)")
    axs[1].set_ylabel("Insulin (mU/min)"); axs[1].set_ylim([0,25]); axs[1].grid(True); axs[1].legend()

    if u_phys_hist.shape[1] > 1:
        axs[2].step(t_vec, u_phys_hist[:,1], where='post', label="Glucagon infusion (mg/min)")
        axs[2].set_ylim([-0.05,0.5])
    else:
        axs[2].plot(t_vec, np.zeros_like(t_vec), label="Glucagon (unused)")
    axs[2].set_ylabel("Glucagon (mg/min)"); axs[2].grid(True); axs[2].legend()

    axs[3].plot(t_vec, g_app_hist, drawstyle='steps-post', label="meal appearance (mg/dL/min)")
    axs[3].set_ylabel("Meal\n(mg/dL/min)"); axs[3].set_xlabel("Time (minutes)"); axs[3].grid(True)

    for tmin, mag in meal_schedule:
        axs[0].axvline(tmin, color='red', linestyle=':', alpha=0.6)
        axs[0].text(tmin+2, axs[0].get_ylim()[1]-5, f"meal {int(mag)}", color="red", rotation=90, va="top")

    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()
