"""
MPC_controller_LY.py

Constrained linear MPC for the Sorensen linearised model.

REQUIREMENT:
 - The repository module LINEARISED_MODEL_TPB.py exports continuous-time linearisation:
     Ac : (n x n) continuous-time A matrix
     Bc : (n x m) continuous-time B matrix
     C  : (1 x n) output matrix measuring glucose (row vector or 1D)
     tau_s : sampling time in MINUTES (scalar)
   Optionally:
     x_star : equilibrium state (n,)
     u_star : equilibrium input (m,)

The script will:
 - Discretise (Ac,Bc) with a ZOH using tau_s (minutes -> seconds conversion).
 - Build and solve a constrained MPC QP (cvxpy, OSQP).
 - Simulate closed-loop on the discrete LTI plant x_{k+1} = A_d x_k + B_d u_k.
 - Plot glucose (C x) and control inputs (insulin, glucagon).

"""

import sys
import importlib
import numpy as np
import matplotlib.pyplot as plt
from scipy import signal
import cvxpy as cp


# Load continuous linear model from LINEARISED_MODEL_TPB
def load_continuous_linear_model():
    modname = "LINEARISED_MODEL_TPB"
    try:
        mod = importlib.import_module(modname)
    except Exception as e:
        raise RuntimeError(f"Unable to import module '{modname}'. Make sure '{modname}.py' is in the working directory. Import error: {e}")

    # Required continuous matrices
    A = getattr(mod, "A", None)
    B = getattr(mod, "B", None)
    C = getattr(mod, "C", None)
    tau_s = getattr(mod, "tau_s", None)  # sampling time in minutes

    # fallback if linearised model is not found
    missing = []
    if A is None: missing.append("A")
    if B is None: missing.append("B")
    if C is None: missing.append("C")
    if tau_s is None: missing.append("tau_s (sampling time in minutes)")

    if missing:
        raise RuntimeError(f"Module '{modname}' is missing required items: {missing}. "
                           "This script requires continuous-time matrices A, B, C and tau_s. "
                           "No numerical linearisation will be attempted.")

    A = np.asarray(A, dtype=float)
    B = np.asarray(B, dtype=float)
    C = np.asarray(C, dtype=float)
    if C.ndim == 1:
        C = C.reshape((1, -1))

    tau_s = float(tau_s)
    x_star = getattr(mod, "x_star", None)
    u_star = getattr(mod, "u_star", None)

    return {"A": A, "B": B, "C": C, "tau_s": tau_s, "x_star": x_star, "u_star": u_star, "source": modname}


# ZOH discretisation (converts minutes -> seconds)
def zoh_discretise(A, B, tau_s_min):
    """
    Discretise continuous (A,B) with zero-order hold.
    tau_s_min: sampling time in minutes (convert to seconds for cont2discrete).
    Returns A_d, B_d
    """
    sec = tau_s_min * 60.0
    # cont2discrete expects (A,B,C,D) and dt in seconds
    # use D = zeros
    D = np.zeros((1, A.shape[0]))
    try:
        A_d, B_d, _, _, _ = signal.cont2discrete((A, B, np.zeros((1, A.shape[0])), 0.0), sec, method="zoh")
    except Exception as e:
        # some scipy versions accept a 4-tuple; fallback:
        try:
            sys_disc = (A, B, np.zeros((1, A.shape[0])), np.zeros((1,1)))
            A_d, B_d, _, _, _ = signal.cont2discrete(sys_disc, sec, method="zoh")
        except Exception as e2:
            raise RuntimeError(f"ZOH discretisation failed: {e}; fallback failed: {e2}")
    return np.asarray(A_d), np.asarray(B_d)

# MPC implementation (condensed QP)
class MPCController:
    def __init__(self, A_d, B_d, C, tau_s=5.0, Np=25, Nc=15,
                 umin=None, umax=None, dumin=None, dumax=None,
                 lambda_u=None, y_min=40.0, y_max=400.0):
        """
        A_d, B_d, C : discrete-time matrices
        tau_s in minutes (informational)
        """
        self.A = np.asarray(A_d, dtype=float)
        self.B = np.asarray(B_d, dtype=float)
        self.C = np.asarray(C, dtype=float).reshape((1, -1))
        self.tau_s = float(tau_s)
        self.Np = int(Np)
        self.Nc = int(min(Nc, Np))
        self.n = self.A.shape[0]
        self.m = self.B.shape[1]

        # Default bounds
        if umin is None:
            umin = np.zeros(self.m)
        if umax is None:
            umax = np.array([80.0, 0.5]) if self.m == 2 else np.ones(self.m) * 1e6
        if dumin is None:
            dumin = -np.array([16.7, 0.1]) if self.m == 2 else -np.ones(self.m) * 1e6
        if dumax is None:
            dumax = np.array([16.7, 0.1]) if self.m == 2 else np.ones(self.m) * 1e6
        if lambda_u is None:
            lambda_u = np.eye(self.m) * 1e-2

        self.umin = np.asarray(umin).reshape((self.m,))
        self.umax = np.asarray(umax).reshape((self.m,))
        self.dumin = np.asarray(dumin).reshape((self.m,))
        self.dumax = np.asarray(dumax).reshape((self.m,))
        self.lambda_u = np.asarray(lambda_u)
        if self.lambda_u.ndim == 1:
            self.lambda_u = np.diag(self.lambda_u)
        self.y_min = float(y_min)
        self.y_max = float(y_max)

        self._build_prediction_matrices()

    def _build_prediction_matrices(self):
        # Phi: stacking C A^i for i=1..Np
        Phi_rows = []
        A_pow = np.eye(self.n)
        for i in range(1, self.Np + 1):
            A_pow = A_pow @ self.A
            Phi_rows.append(self.C @ A_pow)
        self.Phi = np.vstack(Phi_rows)  # (Np x n)

        # H_list: C A^{i-1} B for i=1..Np
        H_list = []
        A_pow = np.eye(self.n)
        for i in range(1, self.Np + 1):
            H_list.append((self.C @ A_pow @ self.B).reshape((1, self.m)))
            A_pow = A_pow @ self.A

        Gamma_full = np.zeros((self.Np, self.m * self.Np))
        for row in range(self.Np):
            for col in range(row + 1):
                Hi = H_list[row - col]  # 1 x m
                Gamma_full[row, col*self.m:(col+1)*self.m] = Hi
        self.Gamma_full = Gamma_full
        self.Gamma = self.Gamma_full[:, :self.m * self.Nc]

    def compute_control(self, xk, uk_prev, r=90.0, solver=cp.OSQP, verbose=False):
        xk = np.asarray(xk).reshape((self.n,))
        uk_prev = np.asarray(uk_prev).reshape((self.m,))

        # reference vector (Np x 1)
        if np.isscalar(r):
            r_vec = np.ones((self.Np, 1)) * float(r)
        else:
            r = np.asarray(r).reshape(-1)
            if r.size != self.Np:
                raise ValueError("r must be scalar or length Np")
            r_vec = r.reshape((self.Np, 1))

        Y0 = (self.Phi @ xk).reshape((self.Np, 1))

        deltaU = cp.Variable((self.m * self.Nc, 1))

        # cumulative T to form u_seq from deltaU
        m = self.m; Nc = self.Nc; Np = self.Np
        T = np.zeros((m*Nc, m*Nc))
        for i in range(Nc):
            for j in range(i+1):
                T[i*m:(i+1)*m, j*m:(j+1)*m] = np.eye(m)
        uk_prev_repeat = np.tile(uk_prev, Nc).reshape((-1,1))

        Gamma_T = self.Gamma @ T
        Gamma_u0 = self.Gamma @ uk_prev_repeat

        Y_pred = Y0 + Gamma_u0 + Gamma_T @ deltaU

        Lambda_block = np.kron(np.eye(Nc), self.lambda_u)
        obj = cp.sum_squares(Y_pred - r_vec) + cp.quad_form(deltaU, Lambda_block)

        constraints = []
        # Δu bounds
        for i in range(Nc):
            du = deltaU[i*m:(i+1)*m, 0]
            constraints += [du >= self.dumin, du <= self.dumax]
        # u bounds over first Nc steps
        u_seq = uk_prev_repeat + T @ deltaU
        for i in range(Nc):
            ui = u_seq[i*m:(i+1)*m, 0]
            constraints += [ui >= self.umin, ui <= self.umax]
        # output bounds across Np
        constraints += [Y_pred >= self.y_min, Y_pred <= self.y_max]

        prob = cp.Problem(cp.Minimize(obj), constraints)
        prob.solve(solver=solver, verbose=verbose)

        if prob.status not in ["optimal", "optimal_inaccurate"]:
            # fallback: hold previous control
            return uk_prev.copy(), {"status": prob.status}

        deltaU_opt = np.array(deltaU.value).reshape(-1)
        du0 = deltaU_opt[:self.m]
        u0 = uk_prev + du0
        info = {"deltaU_opt": deltaU_opt, "Y_pred": Y_pred.value.reshape(-1), "qp_status": prob.status}
        return u0, info


# Helper: build Bw so that C @ Bw = 1 (unit disturbance -> 1 mg/dL immediate output)
def build_Bw_unit_output(C, n):
    """
    Return Bw (n x 1) such that C @ Bw = 1. If C is degenerate,
    fall back to placing disturbance in first state.
    """
    C = np.asarray(C).reshape((1, -1))
    denom = float(C @ C.T)
    if np.abs(denom) < 1e-9:
        Bw = np.zeros((n, 1))
        Bw[0, 0] = 1.0
    else:
        Bw = (C.T / denom).reshape((n, 1))
    return Bw

# Closed-loop with disturbance schedule (meals)
def run_closed_loop_discrete_with_disturbance(A_d, B_d, C, disturbance_schedule=None, x0=None, u0=None, tau_s=5.0, sim_duration_min=240):
    """
    Simulate discrete plant x_{k+1}=A_d x + B_d u + Bw * d_k with Bw built so C@Bw=1.
    disturbance_schedule: list of (time_minute, magnitude_mg_dl) impulses.
    Returns (t_vec, y, x_hist, u_hist, d_seq)
    """
    A_d = np.asarray(A_d); B_d = np.asarray(B_d); C = np.asarray(C).reshape((1,-1))
    n = A_d.shape[0]; m = B_d.shape[1]

    if x0 is None:
        x = np.zeros(n)
    else:
        x = np.asarray(x0).reshape((-1,))
    if u0 is None:
        u_prev = np.zeros(m)
    else:
        u_prev = np.asarray(u0).reshape((m,))

    sim_steps = int(np.ceil(sim_duration_min / tau_s))
    t_vec = np.arange(sim_steps) * tau_s

    # Build disturbance input Bw so that C @ Bw = 1 (1 mg/dL per unit d_k)
    Bw = build_Bw_unit_output(C, n)  # (n x 1)

    # Build disturbance sequence
    d_seq = np.zeros(sim_steps)
    if disturbance_schedule is not None:
        for (t_min, mag) in disturbance_schedule:
            idx = int(np.round(t_min / tau_s))
            if 0 <= idx < sim_steps:
                d_seq[idx] += float(mag)

    # MPC
    mpc = MPCController(A_d, B_d, C, tau_s=tau_s, Np=25, Nc=15)

    ys = np.zeros(sim_steps)
    xs = np.zeros((sim_steps, n))
    us = np.zeros((sim_steps, m))

    for k in range(sim_steps):
        ys[k] = float((C @ x)[0])
        xs[k,:] = x.copy()

        uk, info = mpc.compute_control(x, u_prev, r=90.0)
        us[k,:] = uk.copy()

        dk = d_seq[k]
        x = A_d @ x + B_d @ uk + (Bw.flatten() * dk)

        u_prev = uk

    return t_vec, ys, xs, us, d_seq


# Closed-loop simulation (discrete LTI)
def run_closed_loop_discrete(A_d, B_d, C, x0=None, u0=None, tau_s=5.0, sim_duration_min=240):
    A_d = np.asarray(A_d); B_d = np.asarray(B_d); C = np.asarray(C).reshape((1, -1))
    n = A_d.shape[0]; m = B_d.shape[1]
    if x0 is None:
        x = np.zeros(n)
    else:
        x = np.asarray(x0).reshape((-1,))
    if u0 is None:
        u_prev = np.zeros(m)
    else:
        u_prev = np.asarray(u0).reshape((m,))

    sim_steps = int(np.ceil(sim_duration_min / tau_s))
    t_vec = np.arange(sim_steps) * tau_s

    mpc = MPCController(A_d, B_d, C, tau_s=tau_s, Np=25, Nc=15)

    ys = np.zeros(sim_steps)
    xs = np.zeros((sim_steps, n))
    us = np.zeros((sim_steps, m))

    for k in range(sim_steps):
        ys[k] = float((C @ x)[0])
        xs[k,:] = x.copy()
        uk, info = mpc.compute_control(x, u_prev, r=90.0)
        us[k,:] = uk.copy()
        # update discrete plant
        x = A_d @ x + B_d @ uk
        u_prev = uk

    return t_vec, ys, xs, us


# Main
def main():
    try:
        model = load_continuous_linear_model()
    except RuntimeError as e:
        print("ERROR:", e)
        sys.exit(1)

    A = model["A"]; B = model["B"]; C = model["C"]; tau_s = model["tau_s"]
    x_star = model.get("x_star", None)
    u_star = model.get("u_star", None)
    source = model.get("source", "LINEARISED_MODEL_TPB")

    print(f"Loaded continuous linear model from '{source}'. A shape {A.shape}, B shape {B.shape}, C shape {C.shape}, tau_s={tau_s} min")
    # Discretise now (ZOH)
    A_d, B_d = zoh_discretise(A, B, tau_s)
    print(f"Discretised with ZOH -> A_d shape {A_d.shape}, B_d shape {B_d.shape}")

    if x_star is None:
        x_star = np.zeros(A_d.shape[0])
        print("Warning: x_star not provided; using zeros.")
    if u_star is None:
        u_star = np.zeros(B_d.shape[1])
        print("Warning: u_star not provided; using zeros.")

    # Simulate closed-loop on discrete LTI
    stim_minutes = 2000
    disturbance_schedule = [
        (60.0, 50.0),    # breakfast at 60 min -> +50 mg/dL bump
        (360.0, 70.0),   # lunch at 360 min -> +70 mg/dL bump
    ]
    print("Simulating closed-loop on discrete LTI model.")
    t_vec, ys, xs, us, d_seq = run_closed_loop_discrete_with_disturbance(A_d, B_d, C, disturbance_schedule=disturbance_schedule, x0=x_star, u0=u_star, tau_s=tau_s, sim_duration_min=stim_minutes)



    # Plot results
    fig, axs = plt.subplots(4, 1, figsize=(10, 9), sharex=True, gridspec_kw={"height_ratios":[2, 1, 1, 0.6]})

    # Glucose
    axs[0].plot(t_vec, ys, label="Glucose (C x)")
    axs[0].axhline(90.0, ls="--", color="k", label="setpoint 90 mg/dL")
    axs[0].set_ylabel("Glucose (mg/dL)")
    axs[0].set_ylim([60, 180])
    axs[0].legend(); axs[0].grid(True)

    axs[1].step(t_vec, us[:,0], where="post", label="Insulin (mU/min)")
    axs[1].set_ylabel("Insulin (mU/min)")
    axs[1].legend(); axs[1].grid(True)

    # Glucagon
    if us.shape[1] > 1:
        axs[2].step(t_vec, us[:,1], where='post', label="Glucagon infusion (mg/min)")
    else:
        axs[2].plot(t_vec, np.zeros_like(t_vec), label="Glucagon (unused)")
    axs[2].set_ylabel("Glucagon (mg/min)")
    axs[2].legend(); axs[2].grid(True)

    # Disturbance pulses (meals)
    axs[3].stem(t_vec, d_seq, basefmt=" ")
    axs[3].set_ylabel("Meal impulse\n(mg/dL)")
    axs[3].set_xlabel("Time (minutes)")
    axs[3].grid(True)

    # annotate meal times
    for (t_min, mag) in disturbance_schedule:
        axs[0].axvline(t_min, color="red", ls=":", alpha=0.6)
        axs[0].text(t_min+2, axs[0].get_ylim()[1]-5, f"meal {mag:.0f}", color="red", rotation=90, va="top")


    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()

